// SkillHub Prisma Schema — PostgreSQL

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model User {
  id               String   @id @default(uuid())
  email            String   @unique
  password         String
  firstName        String
  lastName         String
  role             Role     @default(student)
  avatar           String?
  title            String?
  bio              String?
  location         String?
  company          String?
  companyWebsite   String?
  companySize      String?
  industry         String?
  phone            String?
  profileStrength  Int      @default(20)
  meritCoins       Int      @default(100)
  skills           UserSkill[]
  portfolioPublic  Boolean  @default(true)
  isActive         Boolean  @default(true)
  verified         Boolean  @default(false)
  minTier          String?
  isPremium        Boolean  @default(false)
  trialEndsAt      DateTime?
  createdAt        DateTime @default(now())
  updatedAt        DateTime @updatedAt

  refreshTokens        RefreshToken[]
  enrollments          Enrollment[]
  enrolledPaths        SkillPathEnrollment[]  @relation("UserSkillPathEnrollments")
  applications         Application[]
  savedJobs            SavedJob[]
  certificates         Certificate[]
  projects             Project[]
  notifications        Notification[]
  transactions         Transaction[]
  settings             UserSettings?
  payments             Payment[]
  subscriptions        Subscription[]
  connectedPlatforms   ConnectedPlatform[]
  externalCertificates ExternalCertificate[]
  affiliateReferrals   AffiliateReferral[]
  passwordResetTokens  PasswordResetToken[]
  resume               ResumeUpload?
  employerShortlists   ShortlistedCandidate[] @relation("EmployerShortlists")
  candidateShortlists  ShortlistedCandidate[] @relation("CandidateShortlists")
  postedJobs           Job[]                  @relation("EmployerJobs")
  communityPosts       CommunityPost[]        @relation("AuthorPosts")
  communityComments    CommunityComment[]     @relation("AuthorComments")
  communityLikes       CommunityLike[]

  @@map("users")
}

enum Role {
  student
  employer
  instructor
  admin
}

model UserSkill {
  id         String   @id @default(uuid())
  userId     String
  name       String
  level      String   @default("beginner")  // beginner | intermediate | advanced | expert
  verified   Boolean  @default(false)
  verifiedAt DateTime?
  createdAt  DateTime @default(now())
  updatedAt  DateTime @updatedAt

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([userId, name])
  @@index([userId])
  @@map("user_skills")
}

model RefreshToken {
  id        String   @id @default(uuid())
  token     String   @unique
  userId    String
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  expiresAt DateTime
  createdAt DateTime @default(now())

  @@map("refresh_tokens")
}

model Course {
  id          String   @id @default(uuid())
  title       String
  provider    String
  category    String
  level       Level    @default(Beginner)
  duration    String
  rating      Float    @default(0)
  enrollCount Int      @default(0)
  price       Float    @default(0)
  thumbnail   String?
  description String?
  isPremium   Boolean  @default(false)
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  enrollments Enrollment[]

  @@map("courses")
}

enum Level {
  Beginner
  Intermediate
  Advanced
}

model Enrollment {
  id          String    @id @default(uuid())
  userId      String
  courseId    String
  progress    Int       @default(0)
  enrolledAt  DateTime  @default(now())
  completedAt DateTime?

  user   User   @relation(fields: [userId], references: [id], onDelete: Cascade)
  course Course @relation(fields: [courseId], references: [id], onDelete: Cascade)

  @@unique([userId, courseId])
  @@map("enrollments")
}

model Job {
  id          String    @id @default(uuid())
  title       String
  company     String
  location    String
  type        String
  salary      String?
  skills      String[]  @default([])
  description String?
  status      JobStatus @default(active)
  minTier     String?
  isPremium   Boolean   @default(false)
  employerId  String?
  createdAt   DateTime  @default(now())
  updatedAt   DateTime  @updatedAt

  employer     User?                  @relation("EmployerJobs", fields: [employerId], references: [id], onDelete: SetNull)
  applications Application[]
  savedBy      SavedJob[]
  shortlistedCandidates ShortlistedCandidate[]

  @@index([employerId, status])
  @@map("jobs")
}

enum JobStatus {
  active
  closed
  draft
}

model Application {
  id          String            @id @default(uuid())
  userId      String
  jobId       String
  coverLetter String?
  status      ApplicationStatus @default(applied)
  appliedAt   DateTime          @default(now())
  updatedAt   DateTime          @updatedAt

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)
  job  Job  @relation(fields: [jobId], references: [id], onDelete: Cascade)

  @@unique([userId, jobId])
  @@index([status])
  @@index([userId, status])
  @@map("applications")
}

enum ApplicationStatus {
  applied
  reviewing
  shortlisted
  interviewing
  hired
  rejected
}

model SavedJob {
  id      String   @id @default(uuid())
  userId  String
  jobId   String
  savedAt DateTime @default(now())

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)
  job  Job  @relation(fields: [jobId], references: [id], onDelete: Cascade)

  @@unique([userId, jobId])
  @@map("saved_jobs")
}

model Certificate {
  id           String            @id @default(uuid())
  userId       String
  title        String
  provider     String
  issueDate    DateTime?
  expiryDate   DateTime?
  status       CertificateStatus @default(pending)
  credentialId String?
  credentialUrl String?
  fileUrl      String?
  issuedAt     DateTime?
  verifiedAt   DateTime?
  verifiedBy   String?
  createdAt    DateTime          @default(now())

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@map("certificates")
}

enum CertificateStatus {
  pending
  verified
  rejected
}

model Project {
  id           String   @id @default(uuid())
  userId       String
  title        String
  description  String?
  technologies String[] @default([])
  techStack    String[] @default([])
  liveUrl      String?
  githubUrl    String?
  thumbnail    String?
  score        Float    @default(8.0)
  views        Int      @default(0)
  visibility   String   @default("public")
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@map("projects")
}

model Notification {
  id        String   @id @default(uuid())
  userId    String
  type      String
  icon      String?
  title     String   @default("")
  message   String
  read      Boolean  @default(false)
  createdAt DateTime @default(now())

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@map("notifications")
}

model Transaction {
  id           String   @id @default(uuid())
  userId       String
  type         String
  amount       Int
  description  String
  balanceAfter Int
  createdAt    DateTime @default(now())

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@map("transactions")
}

model UserSettings {
  id             String   @id @default(uuid())
  userId         String   @unique
  emailNotifs    Boolean  @default(true)
  pushNotifs     Boolean  @default(true)
  jobAlerts      Boolean  @default(true)
  courseUpdates  Boolean  @default(true)
  weeklyDigest   Boolean  @default(false)
  profileVisible Boolean  @default(true)
  showEmail      Boolean  @default(false)
  showLocation   Boolean  @default(true)
  theme          String   @default("light")
  language       String   @default("en")
  timezone       String   @default("Africa/Lagos")
  updatedAt      DateTime @updatedAt

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@map("user_settings")
}

model Payment {
  id             String         @id @default(uuid())
  userId         String
  amount         Int
  currency       String         @default("NGN")
  status         PaymentStatus  @default(pending)
  paystackRef    String         @unique
  paystackTrxRef String?
  purpose        PaymentPurpose
  metadata       Json?
  paidAt         DateTime?
  createdAt      DateTime       @default(now())
  updatedAt      DateTime       @updatedAt

  user         User          @relation(fields: [userId], references: [id], onDelete: Cascade)
  subscription Subscription?

  @@map("payments")
}

enum PaymentStatus {
  pending
  success
  failed
  abandoned
  refunded
}

enum PaymentPurpose {
  subscription
  merit_coins
  course
  featured_profile
}

model Subscription {
  id        String             @id @default(uuid())
  userId    String
  paymentId String             @unique
  plan      SubscriptionPlan
  status    SubscriptionStatus @default(active)
  startDate DateTime           @default(now())
  endDate   DateTime
  autoRenew Boolean            @default(true)
  createdAt DateTime           @default(now())
  updatedAt DateTime           @updatedAt

  user    User    @relation(fields: [userId], references: [id], onDelete: Cascade)
  payment Payment @relation(fields: [paymentId], references: [id])

  @@map("subscriptions")
}

enum SubscriptionPlan {
  pro_monthly
  pro_annual
  employer_monthly
  employer_annual
}

enum SubscriptionStatus {
  active
  expired
  cancelled
  paused
}

model SkillPath {
  id          String   @id @default(uuid())
  title       String
  description String
  category    String
  level       String   @default("Beginner")
  thumbnail   String?
  tags        String[] @default([])
  published   Boolean  @default(false)
  createdBy   String
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  courses     SkillPathCourse[]
  enrollments SkillPathEnrollment[]

  @@map("skill_paths")
}

model SkillPathCourse {
  id          String  @id @default(uuid())
  pathId      String
  title       String
  provider    String
  url         String
  duration    String?
  description String?
  isRequired  Boolean @default(true)
  order       Int     @default(0)

  path        SkillPath                  @relation(fields: [pathId], references: [id], onDelete: Cascade)
  completions SkillPathCourseCompletion[]

  @@map("skill_path_courses")
}

model SkillPathEnrollment {
  id          String    @id @default(uuid())
  userId      String
  pathId      String
  progress    Int       @default(0)
  enrolledAt  DateTime  @default(now())
  completedAt DateTime?

  user             User                       @relation("UserSkillPathEnrollments", fields: [userId], references: [id], onDelete: Cascade)
  path             SkillPath                  @relation(fields: [pathId], references: [id], onDelete: Cascade)
  completedCourses SkillPathCourseCompletion[]

  @@unique([userId, pathId])
  @@map("skill_path_enrollments")
}

model SkillPathCourseCompletion {
  id           String   @id @default(uuid())
  enrollmentId String
  courseId     String
  completedAt  DateTime @default(now())

  enrollment SkillPathEnrollment @relation(fields: [enrollmentId], references: [id], onDelete: Cascade)
  course     SkillPathCourse     @relation(fields: [courseId], references: [id], onDelete: Cascade)

  @@unique([enrollmentId, courseId])
  @@map("skill_path_course_completions")
}

model ResumeUpload {
  id         String   @id @default(uuid())
  userId     String   @unique
  fileUrl    String
  fileName   String
  uploadedAt DateTime @default(now())
  updatedAt  DateTime @updatedAt

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@map("resume_uploads")
}

model ShortlistedCandidate {
  id          String   @id @default(uuid())
  employerId  String
  candidateId String
  jobId       String?
  note        String?
  createdAt   DateTime @default(now())

  employer  User  @relation("EmployerShortlists",  fields: [employerId],  references: [id], onDelete: Cascade)
  candidate User  @relation("CandidateShortlists", fields: [candidateId], references: [id], onDelete: Cascade)
  job       Job?  @relation(fields: [jobId], references: [id], onDelete: SetNull)

  @@unique([employerId, candidateId, jobId])
  @@map("shortlisted_candidates")
}

model ConnectedPlatform {
  id           String    @id @default(uuid())
  userId       String
  platform     String
  referralCode String?
  connectedAt  DateTime  @default(now())
  lastSyncAt   DateTime?

  user         User                  @relation(fields: [userId], references: [id], onDelete: Cascade)
  certificates ExternalCertificate[]
  referrals    AffiliateReferral[]

  @@unique([userId, platform])
  @@index([userId, platform])
  @@map("connected_platforms")
}

model ExternalCertificate {
  id            String   @id @default(uuid())
  userId        String
  platformId    String
  title         String
  platform      String
  issuer        String
  completedAt   DateTime
  credentialUrl String?
  thumbnailUrl  String?
  skills        String[] @default([])
  createdAt     DateTime @default(now())

  user         User              @relation(fields: [userId], references: [id], onDelete: Cascade)
  platformConn ConnectedPlatform @relation(fields: [platformId], references: [id], onDelete: Cascade)

  @@map("external_certificates")
}

model AffiliateReferral {
  id          String    @id @default(uuid())
  userId      String
  platformId  String
  platform    String
  referralTag String
  clickedAt   DateTime  @default(now())
  converted   Boolean   @default(false)
  convertedAt DateTime?
  commission  Float?

  user         User              @relation(fields: [userId], references: [id], onDelete: Cascade)
  platformConn ConnectedPlatform @relation(fields: [platformId], references: [id], onDelete: Cascade)

  @@map("affiliate_referrals")
}

model PasswordResetToken {
  id        String    @id @default(uuid())
  userId    String
  token     String    @unique
  expiresAt DateTime
  usedAt    DateTime?
  createdAt DateTime  @default(now())

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@map("password_reset_tokens")
}

model CommunityPost {
  id         String   @id @default(uuid())
  authorId   String
  title      String
  body       String
  type       PostType @default(discussion)
  tags       String[] @default([])
  imageUrl   String?
  projectUrl String?
  likes      Int      @default(0)
  views      Int      @default(0)
  isPinned   Boolean  @default(false)
  createdAt  DateTime @default(now())
  updatedAt  DateTime @updatedAt

  author   User              @relation("AuthorPosts",    fields: [authorId], references: [id], onDelete: Cascade)
  comments CommunityComment[]
  postLikes CommunityLike[]

  @@index([authorId])
  @@index([type])
  @@map("community_posts")
}

model CommunityComment {
  id        String   @id @default(uuid())
  postId    String
  authorId  String
  body      String
  likes     Int      @default(0)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  post   CommunityPost @relation(fields: [postId],   references: [id], onDelete: Cascade)
  author User          @relation("AuthorComments",   fields: [authorId], references: [id], onDelete: Cascade)
  commentLikes CommunityLike[]

  @@index([postId])
  @@map("community_comments")
}

model CommunityLike {
  id        String   @id @default(uuid())
  userId    String
  postId    String?
  commentId String?
  createdAt DateTime @default(now())

  user    User              @relation(fields: [userId], references: [id], onDelete: Cascade)
  post    CommunityPost?    @relation(fields: [postId],    references: [id], onDelete: Cascade)
  comment CommunityComment? @relation(fields: [commentId], references: [id], onDelete: Cascade)

  @@unique([userId, postId])
  @@unique([userId, commentId])
  @@map("community_likes")
}

enum PostType {
  discussion
  project
  resource
  question
  showcase
}