// SkillHub Prisma Schema — PostgreSQL

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model User {
  id               String   @id @default(uuid())
  email            String   @unique
  password         String
  firstName        String
  lastName         String
  role             Role     @default(student)
  avatar           String?
  title            String?
  bio              String?
  location         String?
  company          String?
  companyLogo      String?
  companyWebsite   String?
  companySize      String?
  industry         String?
  interestNiche    String?
  phone            String?
  profileStrength  Int      @default(20)
  meritCoins       Int      @default(5)
  skills           UserSkill[]
  portfolioPublic  Boolean  @default(true)
  isActive         Boolean  @default(true)
  verified         Boolean  @default(false)
  minTier          String?
  isPremium        Boolean  @default(false)
  trialEndsAt      DateTime?
  createdAt        DateTime @default(now())
  updatedAt        DateTime @updatedAt
  

  googleId         String?
  appleId          String?

  refreshTokens        RefreshToken[]
  enrollments          Enrollment[]
  enrolledPaths        SkillPathEnrollment[]  @relation("UserSkillPathEnrollments")
  applications         Application[]
  savedJobs            SavedJob[]
  certificates         Certificate[]
  projects             Project[]
  notifications        Notification[]
  transactions         Transaction[]
  settings             UserSettings?
  payments             Payment[]
  subscriptions        Subscription[]
  connectedPlatforms   ConnectedPlatform[]
  externalCertificates ExternalCertificate[]
  affiliateReferrals   AffiliateReferral[]
  passwordResetTokens  PasswordResetToken[]
  resume               ResumeUpload?
  employerShortlists   ShortlistedCandidate[] @relation("EmployerShortlists")
  candidateShortlists  ShortlistedCandidate[] @relation("CandidateShortlists")
  postedJobs           Job[]                  @relation("EmployerJobs")
  communityPosts       CommunityPost[]        @relation("AuthorPosts")
  communityComments    CommunityComment[]     @relation("AuthorComments")
  communityLikes       CommunityLike[]
  sessions             UserSession[]
  activityFeed         ActivityFeed[]
  aiResume             AiResume?
  jobScoutAlerts       JobScoutAlert[]
  sentMessages         DirectMessage[]        @relation("SentMessages")
  receivedMessages     DirectMessage[]        @relation("ReceivedMessages")
  sharedPosts          PostShare[]
  sharedProjects       ProjectShare[]

  @@map("users")
}

enum Role {
  student
  employer
  instructor
  admin
}

model UserSkill {
  id         String   @id @default(uuid())
  userId     String
  name       String
  level      String   @default("beginner")  // beginner | intermediate | advanced | expert
  verified   Boolean  @default(false)
  verifiedAt DateTime?
  createdAt  DateTime @default(now())
  updatedAt  DateTime @updatedAt

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([userId, name])
  @@index([userId])
  @@map("user_skills")
}

model RefreshToken {
  id        String   @id @default(uuid())
  token     String   @unique
  userId    String
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  expiresAt DateTime
  createdAt DateTime @default(now())

  @@map("refresh_tokens")
}

model Course {
  id          String   @id @default(uuid())
  title       String
  provider    String
  category    String
  level       Level    @default(Beginner)
  duration    String
  rating      Float    @default(0)
  enrollCount Int      @default(0)
  price       Float    @default(0)
  thumbnail   String?
  description String?
  isPremium   Boolean  @default(false)
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  @@map("courses")
}

enum Level {
  Beginner
  Intermediate
  Advanced
}

model Enrollment {
  id          String    @id @default(uuid())
  userId      String
  courseId    String
  // 'local'      → courseId is a local Course.id (legacy/seeded courses)
  // 'meritlives' → courseId is a Digital Skills course id; course data is
  //                always fetched live from Digital Skills' API and never
  //                duplicated or stored here. No FK constraint, since this
  //                column can hold IDs from a different database entirely.
  source      String    @default("local")
  // Denormalized snapshot captured at enroll time, so analytics features
  // (e.g. skill decay) don't need to join out to an external API for a
  // value that essentially never changes after enrollment.
  category    String?
  title       String?
  progress    Int       @default(0)
  enrolledAt  DateTime  @default(now())
  completedAt DateTime?

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([userId, courseId, source])
  @@index([courseId, source])
  @@map("enrollments")
}

model Job {
  id          String    @id @default(uuid())
  title       String
  company     String
  location    String
  type        String
  salary      String?
  skills      String[]  @default([])
  description String?
  status      JobStatus @default(active)
  minTier     String?
  isPremium   Boolean   @default(false)
  employerId  String?
  createdAt   DateTime  @default(now())
  updatedAt   DateTime  @updatedAt

  employer     User?                  @relation("EmployerJobs", fields: [employerId], references: [id], onDelete: SetNull)
  applications Application[]
  savedBy      SavedJob[]
  shortlistedCandidates ShortlistedCandidate[]

  @@index([employerId, status])
  @@map("jobs")
}

enum JobStatus {
  active
  closed
  draft
}

model Application {
  id          String            @id @default(uuid())
  userId      String
  jobId       String
  coverLetter String?
  status      ApplicationStatus @default(applied)
  appliedAt   DateTime          @default(now())
  updatedAt   DateTime          @updatedAt

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)
  job  Job  @relation(fields: [jobId], references: [id], onDelete: Cascade)

  @@unique([userId, jobId])
  @@index([status])
  @@index([userId, status])
  @@map("applications")
}

enum ApplicationStatus {
  applied
  reviewing
  shortlisted
  interviewing
  hired
  rejected
}

model SavedJob {
  id      String   @id @default(uuid())
  userId  String
  jobId   String
  savedAt DateTime @default(now())

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)
  job  Job  @relation(fields: [jobId], references: [id], onDelete: Cascade)

  @@unique([userId, jobId])
  @@map("saved_jobs")
}

model Certificate {
  id           String            @id @default(uuid())
  userId       String
  title        String
  provider     String
  issueDate    DateTime?
  expiryDate   DateTime?
  status       CertificateStatus @default(pending)
  credentialId String?
  credentialUrl String?
  fileUrl      String?
  issuedAt     DateTime?
  verifiedAt   DateTime?
  verifiedBy   String?
  createdAt    DateTime          @default(now())

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@map("certificates")
}

enum CertificateStatus {
  pending
  verified
  rejected
}

model Project {
  id           String   @id @default(uuid())
  userId       String
  title        String
  description  String?
  technologies String[] @default([])
  techStack    String[] @default([])
  liveUrl      String?
  githubUrl    String?
  thumbnail    String?
  score        Float    @default(8.0)
  views        Int      @default(0)
  visibility   String   @default("public")
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt

  user   User           @relation(fields: [userId], references: [id], onDelete: Cascade)
  shares ProjectShare[]

  @@map("projects")
}

model Notification {
  id        String   @id @default(uuid())
  userId    String
  type      String
  icon      String?
  title     String   @default("")
  message   String
  read      Boolean  @default(false)
  createdAt DateTime @default(now())

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@map("notifications")
}

model Transaction {
  id           String   @id @default(uuid())
  userId       String
  type         String
  amount       Int
  description  String
  balanceAfter Int
  createdAt    DateTime @default(now())

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@map("transactions")
}

model UserSettings {
  id             String   @id @default(uuid())
  userId         String   @unique
  emailNotifs    Boolean  @default(true)
  pushNotifs     Boolean  @default(true)
  jobAlerts      Boolean  @default(true)
  courseUpdates  Boolean  @default(true)
  weeklyDigest   Boolean  @default(false)
  profileVisible Boolean  @default(true)
  showEmail      Boolean  @default(false)
  showLocation   Boolean  @default(true)
  theme          String   @default("light")
  language       String   @default("en")
  timezone       String   @default("Africa/Lagos")
  updatedAt      DateTime @updatedAt

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@map("user_settings")
}

model Payment {
  id             String         @id @default(uuid())
  userId         String
  amount         Int            // always stored in kobo (NGN basis) for Paystack; USD cents for PayPal
  currency       String         @default("NGN")
  provider       String         @default("paystack")  // "paystack" | "paypal"
  status         PaymentStatus  @default(pending)

  // Paystack fields (null for PayPal payments)
  paystackRef    String?        @unique
  paystackTrxRef String?

  // PayPal fields (null for Paystack payments)
  paypalOrderId  String?        @unique
  paypalCaptureId String?

  purpose        PaymentPurpose
  metadata       Json?
  paidAt         DateTime?
  createdAt      DateTime       @default(now())
  updatedAt      DateTime       @updatedAt

  user         User          @relation(fields: [userId], references: [id], onDelete: Cascade)
  subscription Subscription?

  @@index([userId])
  @@index([userId, status])
  @@map("payments")
}

enum PaymentStatus {
  pending
  success
  failed
  abandoned
  refunded
}

enum PaymentPurpose {
  subscription
  merit_coins
  course
  featured_profile
}

model Subscription {
  id        String             @id @default(uuid())
  userId    String
  paymentId String             @unique
  plan      SubscriptionPlan
  status    SubscriptionStatus @default(active)
  startDate DateTime           @default(now())
  endDate   DateTime
  autoRenew Boolean            @default(true)
  createdAt DateTime           @default(now())
  updatedAt DateTime           @updatedAt

  user    User    @relation(fields: [userId], references: [id], onDelete: Cascade)
  payment Payment @relation(fields: [paymentId], references: [id])

  @@map("subscriptions")
}

enum SubscriptionPlan {
  pro_monthly
  pro_annual
  employer_monthly
  employer_annual
}

enum SubscriptionStatus {
  active
  expired
  cancelled
  paused
}

model SkillPath {
  id          String   @id @default(uuid())
  title       String
  description String
  category    String
  level       String   @default("Beginner")
  thumbnail   String?
  tags        String[] @default([])
  published   Boolean  @default(false)
  createdBy   String
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  courses     SkillPathCourse[]
  enrollments SkillPathEnrollment[]

  @@map("skill_paths")
}

model SkillPathCourse {
  id          String  @id @default(uuid())
  pathId      String
  title       String
  provider    String
  url         String
  duration    String?
  description String?
  isRequired  Boolean @default(true)
  order       Int     @default(0)

  path        SkillPath                  @relation(fields: [pathId], references: [id], onDelete: Cascade)
  completions SkillPathCourseCompletion[]

  @@map("skill_path_courses")
}

model SkillPathEnrollment {
  id          String    @id @default(uuid())
  userId      String
  pathId      String
  progress    Int       @default(0)
  enrolledAt  DateTime  @default(now())
  completedAt DateTime?

  user             User                       @relation("UserSkillPathEnrollments", fields: [userId], references: [id], onDelete: Cascade)
  path             SkillPath                  @relation(fields: [pathId], references: [id], onDelete: Cascade)
  completedCourses SkillPathCourseCompletion[]

  @@unique([userId, pathId])
  @@map("skill_path_enrollments")
}

model SkillPathCourseCompletion {
  id           String   @id @default(uuid())
  enrollmentId String
  courseId     String
  completedAt  DateTime @default(now())

  enrollment SkillPathEnrollment @relation(fields: [enrollmentId], references: [id], onDelete: Cascade)
  course     SkillPathCourse     @relation(fields: [courseId], references: [id], onDelete: Cascade)

  @@unique([enrollmentId, courseId])
  @@map("skill_path_course_completions")
}

model ResumeUpload {
  id         String   @id @default(uuid())
  userId     String   @unique
  fileUrl    String
  fileName   String
  uploadedAt DateTime @default(now())
  updatedAt  DateTime @updatedAt

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@map("resume_uploads")
}

model ShortlistedCandidate {
  id          String   @id @default(uuid())
  employerId  String
  candidateId String
  jobId       String?
  note        String?
  createdAt   DateTime @default(now())

  employer  User  @relation("EmployerShortlists",  fields: [employerId],  references: [id], onDelete: Cascade)
  candidate User  @relation("CandidateShortlists", fields: [candidateId], references: [id], onDelete: Cascade)
  job       Job?  @relation(fields: [jobId], references: [id], onDelete: SetNull)

  @@unique([employerId, candidateId, jobId])
  @@map("shortlisted_candidates")
}

model ConnectedPlatform {
  id           String    @id @default(uuid())
  userId       String
  platform     String
  referralCode String?
  connectedAt  DateTime  @default(now())
  lastSyncAt   DateTime?

  user         User                  @relation(fields: [userId], references: [id], onDelete: Cascade)
  certificates ExternalCertificate[]
  referrals    AffiliateReferral[]

  @@unique([userId, platform])
  @@index([userId, platform])
  @@map("connected_platforms")
}

model ExternalCertificate {
  id            String   @id @default(uuid())
  userId        String
  platformId    String
  title         String
  platform      String
  issuer        String
  completedAt   DateTime
  credentialUrl String?
  thumbnailUrl  String?
  skills        String[] @default([])
  createdAt     DateTime @default(now())

  user         User              @relation(fields: [userId], references: [id], onDelete: Cascade)
  platformConn ConnectedPlatform @relation(fields: [platformId], references: [id], onDelete: Cascade)

  @@map("external_certificates")
}

model AffiliateReferral {
  id          String    @id @default(uuid())
  userId      String
  platformId  String
  platform    String
  referralTag String
  clickedAt   DateTime  @default(now())
  converted   Boolean   @default(false)
  convertedAt DateTime?
  commission  Float?

  user         User              @relation(fields: [userId], references: [id], onDelete: Cascade)
  platformConn ConnectedPlatform @relation(fields: [platformId], references: [id], onDelete: Cascade)

  earnings AffiliateEarning[]  

  @@map("affiliate_referrals")
}

model AffiliateEarning {
  id               String                 @id @default(uuid())
  platform         String                 // "udemy" | "coursera" | "edx" etc.
  network          String                 // "impact" | "rakuten" | "shareasale" | "manual"
  referralTag      String                 // affiliate tag / sub-id used
  orderId          String?                // order / transaction ID from the network
  orderAmount      Float                  // full purchase amount the user paid
  commissionAmount Float                  // what SkillHub earns from this sale
  currency         String                 @default("USD")
  status           AffiliateEarningStatus @default(pending)
  convertedAt      DateTime               @default(now())
  lockedAt         DateTime?              // commission confirmed (past return window)
  paidAt           DateTime?              // money transferred to SkillHub bank
  rawPayload       Json?                  // full webhook body for audit
  createdAt        DateTime               @default(now())
  updatedAt        DateTime               @updatedAt

  referralId String?
  referral   AffiliateReferral? @relation(fields: [referralId], references: [id], onDelete: SetNull)

  @@index([platform])
  @@index([status])
  @@index([convertedAt])
  @@map("affiliate_earnings")
}

enum AffiliateEarningStatus {
  pending    // sale event received, awaiting confirmation
  confirmed  // network confirmed (still in return window)
  locked     // return window passed — commission guaranteed
  paid       // transferred to SkillHub bank account
  reversed   // refund / chargeback — commission cancelled
}


model PasswordResetToken {
  id        String    @id @default(uuid())
  userId    String
  token     String    @unique
  expiresAt DateTime
  usedAt    DateTime?
  createdAt DateTime  @default(now())

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@map("password_reset_tokens")
}

model CommunityPost {
  id         String   @id @default(uuid())
  authorId   String
  title      String
  body       String
  type       PostType @default(discussion)
  tags       String[] @default([])
  imageUrl   String?
  projectUrl String?
  likes      Int      @default(0)
  views      Int      @default(0)
  isPinned   Boolean  @default(false)
  createdAt  DateTime @default(now())
  updatedAt  DateTime @updatedAt

  author   User              @relation("AuthorPosts",    fields: [authorId], references: [id], onDelete: Cascade)
  comments CommunityComment[]
  postLikes CommunityLike[]
  shares   PostShare[]

  @@index([authorId])
  @@index([type])
  @@map("community_posts")
}

model CommunityComment {
  id        String   @id @default(uuid())
  postId    String
  authorId  String
  body      String
  likes     Int      @default(0)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  post   CommunityPost @relation(fields: [postId],   references: [id], onDelete: Cascade)
  author User          @relation("AuthorComments",   fields: [authorId], references: [id], onDelete: Cascade)
  commentLikes CommunityLike[]

  @@index([postId])
  @@map("community_comments")
}

model CommunityLike {
  id        String   @id @default(uuid())
  userId    String
  postId    String?
  commentId String?
  reactionType String?
  createdAt DateTime @default(now())

  user    User              @relation(fields: [userId], references: [id], onDelete: Cascade)
  post    CommunityPost?    @relation(fields: [postId],    references: [id], onDelete: Cascade)
  comment CommunityComment? @relation(fields: [commentId], references: [id], onDelete: Cascade)

  @@unique([userId, postId])
  @@unique([userId, commentId])
  @@map("community_likes")
}

enum PostType {
  discussion
  project
  resource
  question
  showcase
}

model SystemSetting {
  id        String   @id @default(uuid())
  key       String   @unique
  value     String
  updatedAt DateTime @updatedAt
  updatedBy String?

  @@map("system_settings")
}

model UserSession {
  id          String    @id @default(uuid())
  userId      String
  ipAddress   String?
  userAgent   String?
  device      String?
  browser     String?
  os          String?
  country     String?
  city        String?
  lastSeenAt  DateTime  @default(now())
  createdAt   DateTime  @default(now())
  expiresAt   DateTime?
  isActive    Boolean   @default(true)

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
  @@index([lastSeenAt])
  @@map("user_sessions")
}

// ── Activity Feed ────────────────────────────────────────────────────────────
// Every significant user action (course enroll/complete, badge, job apply,
// achievement, community post) is recorded here and surfaced in the community
// activity stream so the feed feels alive and auto-populated.

model ActivityFeed {
  id         String       @id @default(uuid())
  userId     String
  type       ActivityType
  title      String
  body       String?
  // Generic payload — course title, job title, badge name, etc.
  metadata   Json?
  // Optional foreign keys so we can deep-link from activity items
  courseId   String?
  jobId      String?
  postId     String?
  isPublic   Boolean      @default(true)
  createdAt  DateTime     @default(now())

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
  @@index([createdAt])
  @@index([type])
  @@map("activity_feed")
}

enum ActivityType {
  course_enrolled
  course_completed
  course_progress        // milestone: 25 / 50 / 75 %
  digital_skills_enrolled
  digital_skills_completed
  badge_earned
  certificate_added
  project_added
  job_applied
  job_saved
  skill_added
  community_post
  resume_generated
  profile_completed
  member_joined
  streak_milestone       // 7-day / 30-day learning streak
}

// ── AI-Generated Resume ──────────────────────────────────────────────────────
// Stores the last AI-generated resume snapshot for a user.
// Generated on-demand; the backend calls Claude to build it from live data.

model AiResume {
  id          String   @id @default(uuid())
  userId      String   @unique
  // Full markdown/HTML resume text produced by the AI
  content     String   @db.Text
  // Summary of what data was used (for display / transparency)
  dataSummary Json?
  generatedAt DateTime @default(now())
  updatedAt   DateTime @updatedAt

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@map("ai_resumes")
}

// ── Job Scout ────────────────────────────────────────────────────────────────
// Stores AI-discovered job leads before they are sent to students.
// The Job Scout cron searches the web and persists results here,
// then a notification job fans them out to matching students.

model JobScoutLead {
  id          String           @id @default(uuid())
  title       String
  company     String
  location    String?
  type        String?          // full-time | part-time | remote | contract
  salary      String?
  description String?          @db.Text
  url         String
  source      String           // "linkedin" | "indeed" | "twitter" | "web"
  niche       String           // matches User.interestNiche
  skills      String[]         @default([])
  postedAt    DateTime?
  fetchedAt   DateTime         @default(now())
  status      JobScoutStatus   @default(pending)

  sentAlerts JobScoutAlert[]

  @@unique([url, niche])
  @@index([niche])
  @@index([status])
  @@index([fetchedAt])
  @@map("job_scout_leads")
}

enum JobScoutStatus {
  pending   // fetched, not yet sent
  sent      // alerts dispatched
  expired   // older than 7 days
}

// ── Job Scout Alert (per-student delivery record) ────────────────────────────
model JobScoutAlert {
  id        String   @id @default(uuid())
  leadId    String
  userId    String
  sentAt    DateTime @default(now())
  opened    Boolean  @default(false)
  applied   Boolean  @default(false)

  lead JobScoutLead @relation(fields: [leadId], references: [id], onDelete: Cascade)
  user User         @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([leadId, userId])
  @@index([userId])
  @@map("job_scout_alerts")
}
// ── Direct Messages ──────────────────────────────────────────────────────────
// Private 1:1 messages between users. Messages are ephemeral by design — a
// cleanup job removes any message older than 24 hours. The most recent message
// per conversation is what surfaces in the contacts list before expiry.
model DirectMessage {
  id          String   @id @default(uuid())
  senderId    String
  recipientId String
  body        String   @db.Text
  read        Boolean  @default(false)
  createdAt   DateTime @default(now())

  sender    User @relation("SentMessages",     fields: [senderId],    references: [id], onDelete: Cascade)
  recipient User @relation("ReceivedMessages", fields: [recipientId], references: [id], onDelete: Cascade)

  @@index([recipientId, senderId])
  @@index([senderId, recipientId])
  @@index([createdAt])
  @@map("direct_messages")
}

// ── Post Shares ──────────────────────────────────────────────────────────────
// Tracks when a user shares a community post. Shared posts are visible on user
// profiles and in a dedicated "shares" section.
model PostShare {
  id        String   @id @default(uuid())
  userId    String
  postId    String
  note      String?  @db.Text
  sharedAt  DateTime @default(now())

  user User           @relation(fields: [userId],   references: [id], onDelete: Cascade)
  post CommunityPost  @relation(fields: [postId],   references: [id], onDelete: Cascade)

  @@unique([userId, postId])
  @@index([userId])
  @@index([postId])
  @@map("post_shares")
}

// ── Project Shares ──────────────────────────────────────────────────────────
model ProjectShare {
  id        String   @id @default(uuid())
  userId    String
  projectId String
  note      String?  @db.Text
  sharedAt  DateTime @default(now())

  user    User     @relation(fields: [userId],    references: [id], onDelete: Cascade)
  project Project  @relation(fields: [projectId], references: [id], onDelete: Cascade)

  @@unique([userId, projectId])
  @@index([userId])
  @@index([projectId])
  @@map("project_shares")
}
