# ── Server ────────────────────────────────────────────────────────────────────
PORT=5000
NODE_ENV=development

# ── PostgreSQL (Prisma) ───────────────────────────────────────────────────────
# Local:    postgresql://user:password@localhost:5432/skillhub
# Neon:     postgresql://user:password@ep-xxx.us-east-1.aws.neon.tech/skillhub?sslmode=require
# Supabase: postgresql://postgres:[password]@db.[ref].supabase.co:5432/postgres
DATABASE_URL=postgresql://user:password@localhost:5432/skillhub

# ── JWT ───────────────────────────────────────────────────────────────────────
JWT_SECRET=CHANGE_ME_min_64_chars_random_hex
JWT_EXPIRES_IN=15m
JWT_REFRESH_SECRET=CHANGE_ME_different_secret_also_64_chars
JWT_REFRESH_EXPIRES_IN=30d

# ── Paystack ──────────────────────────────────────────────────────────────────
# Get keys from: https://dashboard.paystack.com/#/settings/developers
# Use test keys (sk_test_...) for development, live keys (sk_live_...) for production
PAYSTACK_SECRET_KEY=sk_test_CHANGE_ME
PAYSTACK_PUBLIC_KEY=pk_test_CHANGE_ME

# Your webhook URL must be registered at:
# https://dashboard.paystack.com/#/settings/developer → Webhooks
# URL: https://yourdomain.com/api/v1/payment/webhook
PAYSTACK_WEBHOOK_URL=https://yourdomain.com/api/v1/payment/webhook

# ── CORS ──────────────────────────────────────────────────────────────────────
FRONTEND_URL=http://localhost:3000

# ── File uploads ──────────────────────────────────────────────────────────────
UPLOAD_DIR=uploads
MAX_FILE_SIZE=10485760

# ── Rate limiting ─────────────────────────────────────────────────────────────
RATE_LIMIT_WINDOW_MS=900000
RATE_LIMIT_MAX=200

# ── Cloudinary (OPTIONAL — only if you want image uploads) ───────────────────
 See README for when you need this. Not required to run the app.
 CLOUDINARY_CLOUD_NAME=your_cloud_name
 CLOUDINARY_API_KEY=your_api_key
 CLOUDINARY_API_SECRET=your_api_secret

 # Email (Resend) — for password reset emails
RESEND_API_KEY=re_REPLACE_ME
EMAIL_FROM=SkillHub <noreply@yourdomain.com>
# ── AI Providers (resume generation + job scout) ─────────────────────────────
# The app tries these in order and falls back automatically if one fails or
# hits its quota. Configure at least ONE. Order is set by AI_PROVIDER_ORDER.
AI_PROVIDER_ORDER=gemini,groq,openrouter

# Google Gemini — https://aistudio.google.com/app/apikey
# (Tip: create the key in a NEW project to get a fresh free quota.)
GEMINI_API_KEY=
GEMINI_MODEL=gemini-2.0-flash

# Groq — https://console.groq.com  (large free daily allowance)
GROQ_API_KEY=
GROQ_MODEL=llama-3.3-70b-versatile

# OpenRouter — https://openrouter.ai  (has free Llama models)
OPENROUTER_API_KEY=
OPENROUTER_MODEL=meta-llama/llama-3.3-70b-instruct:free

# Tavily — https://app.tavily.com  (web search for Job Scout; optional)
TAVILY_API_KEY=